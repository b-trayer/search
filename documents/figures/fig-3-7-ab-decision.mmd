%% Рисунок 3.7 — Дерево решений по результатам онлайн A/B-эксперимента.
%% Опирается на трехуровневую систему метрик из таблицы 3.3 (первичная,
%% вторичные, guardrail) и протокол принятия решений из раздела 3.3.3.
%% Узел SRM — первый санитарный контроль до анализа метрик; guardrail
%% проверяется до первичной метрики; вторичные метрики используются
%% только в подтверждающем режиме.

flowchart TB
    Start([Эксперимент завершен,<br/>длительность ≥ T_min,<br/>условие остановки выполнено])
    Start --> SRM{Sample Ratio Mismatch:<br/>p-value χ² ≥ 0.001?}
    SRM -- "нет" --> SRMfail[/"Эксперимент инвалиден.<br/>Аудит инструментирования и рандомизации.<br/>Запуск повторно после фикса."/]
    SRM -- "да" --> Guard{Guardrail-метрики:<br/>P95 latency, error rate,<br/>empty result rate<br/>не деградировали?}
    Guard -- "нет" --> GuardFail[/"Откат варианта B.<br/>Производительность<br/>важнее CTR-выигрыша."/]
    Guard -- "да" --> Primary{Первичная метрика<br/>CTR top-10 значимо выше<br/>в B (sequential test)?}
    Primary -- "нет, ниже или нейтрально" --> Reject[/"Гипотеза не подтверждена.<br/>Откат варианта B,<br/>ретроспектива."/]
    Primary -- "да, выше" --> Sec{Вторичные метрики<br/>согласованы с первичной?<br/>(MRR↑, dwell↑, reform↓)}
    Sec -- "противоречат" --> Hold[/"Расследование:<br/>возможен gaming CTR<br/>без улучшения релевантности.<br/>Удлинить эксперимент."/]
    Sec -- "согласованы" --> Novelty{Эффект устойчив<br/>после первых 7-14 дней<br/>(контроль primacy/novelty)?}
    Novelty -- "затухает" --> Hold2[/"Краткосрочная новизна.<br/>Удлинить эксперимент<br/>до плато."/]
    Novelty -- "устойчив" --> Accept[/"Раскатка варианта B<br/>на 100%."/]
