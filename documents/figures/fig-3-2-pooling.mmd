%% Рисунок 3.2 — Стратегия пуллинга top-k результатов от трех конфигураций.
%% Цель — устранить смещение оценки в пользу одной из конфигураций.
%% Каждая конфигурация выдает свой топ-100 на запрос q; объединение
%% этих списков (без повторов) образует пул, по которому оракул
%% присваивает gain'ы. После этого все три конфигурации оцениваются
%% на одном и том же пуле, что делает сравнение справедливым:
%% документ, в принципе невидимый для конфигурации, не получает gain
%% не потому, что нерелевантен, а потому, что не попал в верхушку.

flowchart LR
    Q[("Запрос q")]
    Q --> C0["C0: bm25_only"]
    Q --> C2["C2: +персонализация"]
    Q --> C4["C4: полная модель"]
    C0 --> T0["top-100 от C0"]
    C2 --> T2["top-100 от C2"]
    C4 --> T4["top-100 от C4"]
    T0 --> Pool[("Пул(q) =\nT0 ∪ T2 ∪ T4\nбез повторов")]
    T2 --> Pool
    T4 --> Pool
    Pool --> Oracle["Оракул присваивает\ngain ∈ {0,1,2,3}\nкаждому документу пула"]
    Oracle --> Eval{"nDCG@10\nна одном и том же\nоснащенном пуле"}
    Eval --> M0["M(C0, q)"]
    Eval --> M2["M(C2, q)"]
    Eval --> M4["M(C4, q)"]
