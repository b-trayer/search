%% Рисунок 3.5 — Результаты пилотного прогона на боевом стенде anyasthesis.ru.
%% Сравниваются четыре конфигурации ранжирования (default, high_personalization,
%% high_ctr, bm25_only) по nDCG@10, рассчитанному на двух оракулах
%% релевантности: topical (бинарный, профиль пользователя не учитывается) и
%% full (градуированный 0..3, профиль учитывается). Усреднение по 18 запросам.
%%
%% Mermaid xychart рендерит метку оси значениями от 0.0 до 1.0; столбцы
%% сгруппированы по пресетам, для каждого пресета показаны два значения
%% (topical и full) в соседних столбцах одного цвета.

xychart-beta
    title "Pilot: nDCG@10, среднее по 18 запросам"
    x-axis ["bm25_only", "default", "high_ctr", "high_personalization"]
    y-axis "nDCG@10" 0.6 --> 1.0
    bar "topical (guardrail)" [0.933, 0.981, 0.954, 0.982]
    bar "full (target)"       [0.734, 0.912, 0.874, 0.943]
