%% Рисунок 3.6 — Roadmap «бакалаврская работа → магистратура».
%% Слева — артефакты, выполненные в бакалаврской работе. Справа —
%% задачи, выходящие за ее рамки и относящиеся к продолжению
%% исследования. Категория «инструментирование» — мост между
%% бакалаврской и магистратурой: эти артефакты могут быть
%% частично сделаны до магистратуры (например, расширение
%% коллекции запросов до 80–100), частично — внутри.

flowchart LR
    subgraph DONE["Бакалаврская: сделано"]
        direction TB
        D1["Подсистема ранжирования\n(глава 2)"]
        D2["Harness и оракул\n(2.10)"]
        D3["Пилот на 18 запросах\n(3.7)"]
        D4["Дизайн всех\nэкспериментов\n(3.1, 3.4, 3.5, 3.6)"]
    end

    subgraph BRIDGE["Мост: инструментирование"]
        direction TB
        B1["Расширение Q до 80–100\nс экспертной разметкой"]
        B2["Порог релевантности\ngain ≥ 2 в оракуле"]
        B3["SSO + аутентификация"]
        B4["Дашборд экспериментов\n(SRM, sequential)"]
    end

    subgraph MAS["Магистратура: задачи"]
        direction TB
        M1["Реальный\noffline-подбор θ*\n(grid → TPE → UCB)"]
        M2["Запуск online A/B\nна боевом потоке"]
        M3["Замена детерминированного\nоракула на эксперт+оракул"]
        M4["DBN: учет position bias\nв click models"]
        M5["Cross-encoder / ColBERT\nна второй стадии"]
        M6["Long-term effects\nперсонализации"]
        M7["Анти-filter-bubble:\nразнообразие как guardrail"]
    end

    DONE --> BRIDGE
    BRIDGE --> MAS
    D4 --> M1
    D4 --> M2
    B1 --> M1
    B3 --> M2
    B4 --> M2
    M2 --> M6
    M2 --> M7
